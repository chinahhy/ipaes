# ========== 必填 ==========
REPO_BASE_URL=https://your-domain.example.com/your-path   # 公网订阅 URL（必填，无默认值）
REPO_NAME=Private IPA Repo                                # Esign 显示的源名称
REPO_IDENTIFIER=com.private.ipa.repo                      # 源 BundleId（AltStore 唯一标识）

# ========== TG Bot ==========
TG_PROXY=                                                 # 留空=直连，格式: socks5://host:port 或 http://host:port
TG_SCAN_CRON=0 1 * * *                                    # TG 扫描 cron（默认每天 01:00）
TG_SCAN_HOURS=25                                          # 回溯小时数（24h+1h 缓冲）

# ========== 通用 ==========
TZ=Asia/Shanghai

# ========== 宿主机端口（可省略，有默认值）==========
HOST_PORT_NGINX=8080                                      # nginx 源订阅端口
HOST_PORT_WEBUI=8085                                      # WebUI 管理端口

# ========== 挂载路径（可省略，有默认值）==========
IPA_DIR=./data/ipa                                        # IPA 文件存放目录
ICONS_DIR=./data/icons                                    # 图标存放目录
